{
  "metrics": {
    "namespace": "MyWebApp",
    "metrics_collected": {
      "mem": {
        "measurement": ["mem_used_percent"]
      },
      "disk": {
        "measurement": ["disk_used_percent"]
      }
    }
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/httpd/access_log",
            "log_group_name": "MyWebApp-AccessLogs",
            "log_stream_name": "{instance_id}"
          }
        ]
      }
    }
  }
}